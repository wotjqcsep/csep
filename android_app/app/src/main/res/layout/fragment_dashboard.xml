<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F4F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 현황"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="12dp"/>

            <!-- 통계 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_today_new"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-" android:textSize="32sp" android:textStyle="bold" android:textColor="#2563EB"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="신규" android:textSize="12sp" android:textColor="#64748B"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_in_progress"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-" android:textSize="32sp" android:textStyle="bold" android:textColor="#F59E0B"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="진행중" android:textSize="12sp" android:textColor="#64748B"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_assigned"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-" android:textSize="32sp" android:textStyle="bold" android:textColor="#8B5CF6"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="배정대기" android:textSize="12sp" android:textColor="#64748B"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_completed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="-" android:textSize="32sp" android:textStyle="bold" android:textColor="#10B981"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="완료" android:textSize="12sp" android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="미수금 합계  " android:textSize="13sp" android:textColor="#64748B"/>
                        <TextView android:id="@+id/tv_outstanding"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="-" android:textSize="13sp" android:textColor="#DC2626" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 기사 현황 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기사 현황"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tv_engineers"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="불러오는 중..."
                        android:textSize="14sp" android:textColor="#374151" android:lineSpacingExtra="6dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
